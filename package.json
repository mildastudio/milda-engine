{
  "name": "milda-engine",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @mildastudio/core -w @mildastudio/contract -w @mildastudio/generate -w @mildastudio/release",
    "typecheck": "tsc --noEmit -p packages/core && tsc --noEmit -p packages/contract && tsc --noEmit -p packages/generate && tsc --noEmit -p packages/release",
    "check:containment": "tsx packages/core/structure/containment.check.ts"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsup": "^8.5.1",
    "tsx": "^4",
    "typescript": "^5"
  }
}
